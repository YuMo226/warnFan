1:                #include<cms.h>
2:                #include"Display.h"
3:                
4:                unsigned char tcount=0;
5:                
6:                void interrupt ISR()
7:                {
8:                	if(TMR2IF)
  001D    1C8C    SNZB	0xC,1
  001E    2822    JP	0x22
9:                	{
10:               		TMR2IF=0;
  001F    108C    CLRB	0xC,1
11:               		tcount++;
  0020    0AF7    INCR	0x77
12:               		Display();    //显示相关动态扫描函数，需显示时调用
  0021    202E    CALL	0x2E
  0022    0876    LD	A,0x76
  0023    1283    CLRB	0x3,5
  0024    00FF    LD	0x7F,A
  0025    0875    LD	A,0x75
  0026    008A    LD	0xA,A
  0027    0874    LD	A,0x74
  0028    0084    LD	0x4,A
  0029    0E73    SWAPA	0x73
  002A    0083    LD	0x3,A
  002B    0EFE    SWAPR	0x7E
  002C    0E7E    SWAPA	0x7E
  002D    0009    RETI
13:               	}
14:               }
15:               
16:               void main()
  016D    0064    CLRWDT
17:               {
18:               	asm("clrwdt");
19:               	OSCCON=0B01110001;
  016E    3071    LDIA	0x71
  016F    1683    SETB	0x3,5
  0170    1303    CLRB	0x3,6
  0171    008F    LD	0xF,A
20:               	
21:               	PR2=62;        //因为循环增加次数，所以时间缩短一半
  0172    303E    LDIA	0x3E
  0173    0092    LD	0x12,A
22:               	TMR2IF=0;
  0174    1283    CLRB	0x3,5
  0175    108C    CLRB	0xC,1
23:               	TMR2IE=1;
  0176    1683    SETB	0x3,5
  0177    148C    SETB	0xC,1
24:               	T2CON=0B00000101;
  0178    3005    LDIA	0x5
  0179    1283    CLRB	0x3,5
  017A    0092    LD	0x12,A
25:               	
26:               	InitLed();
  017B    120A    CLRB	0xA,4
  017C    118A    CLRB	0xA,3
  017D    21AC    CALL	0x1AC
27:               	
28:               	INTCON=0B11000000;
  0180    30C0    LDIA	0xC0
  0181    008B    LD	0xB,A
29:               	Dis_SC0=1;        //对3位数码管和4个功能对应显示缓冲区赋值
  0182    3001    LDIA	0x1
  0183    00FC    LD	0x7C,A
30:               	Dis_SC1=6;
  0184    3006    LDIA	0x6
  0185    00FB    LD	0x7B,A
31:               	SFan_off;					
  0186    01FA    CLR	0x7A
32:               	SSun_off;			
  0187    01F9    CLR	0x79
33:               	SCircle_on;		
  0188    3001    LDIA	0x1
  0189    00FD    LD	0x7D,A
34:               	SH_on;		
  018A    1283    CLRB	0x3,5
  018B    00A2    LD	0x22,A
35:               	SAD_on;			
  018C    00A1    LD	0x21,A
36:               	SWS_on;
  018D    00A0    LD	0x20,A
37:               	
38:               	while(1)
  018E    0064    CLRWDT
39:               	{
40:               		asm("clrwdt");
41:               		if(tcount>=32)
  018F    3020    LDIA	0x20
  0190    0277    SUBA	0x77
  0191    1C03    SNZB	0x3,0
  0192    298E    JP	0x18E
42:               		{
43:               			tcount=0;
  0193    01F7    CLR	0x77
  0194    298E    JP	0x18E
44:               			
45:               		}
46:               	}
47:               }
---- D:\CMS\CMS_IDE_V2.03.21\works  暖风机\Demo\Display.c ----------------------------------------------------------------------
1:                #include<cms.h>
2:                #include"Display.h"
3:                
4:                /*=============================================================
5:                要在数码管显示内容只要对          
6:                Dis_SC0		//左边
7:                Dis_SC1
8:                Dis_SC2
9:                Dis_SC3		//右边
10:               变量进行赋值即可。
11:               如：
12:               Dis_SC0 = 1; 
13:               即可在最左边的数码管上显示数字“1”
14:               为什么能显示“1”？取决于SegTab[]这个数组，Dis_SC0 = 1，相当于
15:               DisplayData(SegTab[1])，最终控制的是相应的SEG段或者LED对应的IO输出0
16:               如果要显示自己定义的内容，可以在SegTab[]后面添加元素，如果添加的元素
17:               在数据下标的“18”的位置，那么要显示时，需要对Dis_SC0 = 18;
18:               即可显示自己定义的内容。
19:               ===========================================================*/
20:               volatile unsigned char Dis_SC0;  //3位数码管和四个功能对应显示缓冲区变量
21:               volatile unsigned char Dis_SC1;
22:               volatile unsigned char Dis_SFan;
23:               volatile unsigned char Dis_SSun;
24:               volatile unsigned char Dis_SCircle;
25:               volatile unsigned char Dis_SH;
26:               volatile unsigned char Dis_SAD;
27:               volatile unsigned char Dis_SWS;
28:               
29:               //显示的字形数组，如果需要显示表中没有的形状，可以自己在数组后面添加
30:               const unsigned char SegTab[]={
31:               	SMG_0,     //0x3F  
32:               	SMG_1,     //0x06
33:               	SMG_2,
34:               	SMG_3,
35:               	SMG_4,
36:               	SMG_5,
37:               	SMG_6,
38:               	SMG_7,
39:               	SMG_8,
40:               	SMG_9,
41:               	SMG_A,
42:               	SMG_B,
43:               	SMG_C,
44:               	SMG_D,
45:               	SMG_E,
46:               	SMG_F,
47:               	SMG_00,   //16
48:               };
49:               
50:               //相关IO口初始化为输出
51:               void InitLed()
52:               {
53:               	//相应的位与0，即设置成0，与1不会修改原来的值。
54:               	TRISA&=0B11111111;        //设置RA0-2为输出
  01AC    1683    SETB	0x3,5
  01AD    0805    LD	A,0x5
55:               	TRISB&=0B11111111;        //设置RC0-5为输出
  01AE    0806    LD	A,0x6
  01AF    0008    RET
56:               
57:               }
58:               
