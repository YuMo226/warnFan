60:               函数名称：DisplayData（共阴）
61:               函数功能：数码管SEG段显示处理函数。
62:               **********************************************/
63:               void DisplayData(unsigned char data)
  0084    00F0    LD	0x70,A
64:               {
65:               	//共阴，根据入口参数SegTab[]，判断相应位为1，点亮对应SEG段
66:               	if(data&SIGA)
  0085    1C70    SNZB	0x70,0
  0086    288B    JP	0x8B
67:               	{
68:               		TRISA1=0;
  0087    1683    SETB	0x3,5
  0088    1085    CLRB	0x5,1
69:               		SA1=1;
  0089    1283    CLRB	0x3,5
  008A    288C    JP	0x8C
70:               	}
71:               	else
72:               	{
73:               		TRISA1=1;
  008B    1683    SETB	0x3,5
  008C    1485    SETB	0x5,1
74:               
75:               	}
76:               	if(data&SIGB)
  008D    1CF0    SNZB	0x70,1
  008E    2893    JP	0x93
77:               	{
78:               		TRISA2=0;
  008F    1683    SETB	0x3,5
  0090    1105    CLRB	0x5,2
79:               		SB1=1;
  0091    1283    CLRB	0x3,5
  0092    2894    JP	0x94
80:               	}
81:               	else
82:               	{
83:               		TRISA2=1;
  0093    1683    SETB	0x3,5
  0094    1505    SETB	0x5,2
84:               
85:               	}
86:               	if(data&SIGC)
  0095    1D70    SNZB	0x70,2
  0096    289B    JP	0x9B
87:               	{
88:               		TRISB4=0;
  0097    1683    SETB	0x3,5
  0098    1206    CLRB	0x6,4
89:               		SC1=1;
  0099    1283    CLRB	0x3,5
  009A    289C    JP	0x9C
90:               	}else
91:               	{
92:               		TRISB4=1;
  009B    1683    SETB	0x3,5
  009C    1606    SETB	0x6,4
93:               
94:               	}
95:               	if(data&SIGD)
  009D    1DF0    SNZB	0x70,3
  009E    28A0    JP	0xA0
96:               	{
97:               		TRISB5=0;
98:               		SD1=1;
99:               	}else
  009F    2968    JP	0x168
100:              	{
101:              		TRISB5=1;
  00A0    1683    SETB	0x3,5
  00A1    1686    SETB	0x6,5
  00A2    0008    RET
102:              
103:              	}
104:              }
