65:               void PTC_SoftStart(void) {
66:                   unsigned char i;
67:                   
68:                   // чбоф┐Эф╗О 0 х╝АхзЛ
69:                   PTC_SetDuty(0);
70:                   
71:                   // ч║┐цАзхвЮхКахИ░ 100%
72:                   for (i = 0; i <= 100; i++) {
73:                       PTC_SetDuty(i);
74:                       DelayMs(SOFT_START_STEP_DELAY);
75:                   }
76:               }
