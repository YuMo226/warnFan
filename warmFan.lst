44:               void PTC_SetDuty(unsigned char dutyPercent) {
  050C    00D9    LD	0x59,A
45:                   unsigned int dutyRaw;
46:                   
47:                   if (dutyPercent > 100) {
  050D    3065    LDIA	0x65
  050E    0259    SUBA	0x59
  050F    1C03    SNZB	0x3,0
  0510    2D13    JP	0x513
48:                       dutyPercent = 100;
  0511    3064    LDIA	0x64
  0512    00D9    LD	0x59,A
49:                   }
50:                   
51:                   // шобчоЧхОЯхзЛ PWM хА╝
52:                   // цЬАхдзшобцХ░хА╝ = (PR2 + 1) * 4 = 100 * 4 = 400
53:                   // dutyRaw = (dutyPercent * 400) / 100 = dutyPercent * 4
54:                   dutyRaw = (unsigned int)dutyPercent * 4;
  0513    0859    LD	A,0x59
  0514    00D7    LD	0x57,A
  0515    01D8    CLR	0x58
  0516    1003    CLRB	0x3,0
  0517    0DD7    RLCR	0x57
  0518    0DD8    RLCR	0x58
  0519    1003    CLRB	0x3,0
  051A    0DD7    RLCR	0x57
  051B    0DD8    RLCR	0x58
55:                   
56:                   // хЖЩхЕехпДхнШхЩи
57:                   // CCPR2L хнШщлШ8ф╜Н: dutyRaw >> 2
58:                   CCPR2L = (unsigned char)(dutyRaw >> 2);
  051C    0858    LD	A,0x58
  051D    00D6    LD	0x56,A
  051E    0857    LD	A,0x57
  051F    00D5    LD	0x55,A
  0520    1003    CLRB	0x3,0
  0521    0CD6    RRCR	0x56
  0522    0CD5    RRCR	0x55
  0523    1003    CLRB	0x3,0
  0524    0CD6    RRCR	0x56
  0525    0CD5    RRCR	0x55
  0526    0855    LD	A,0x55
  0527    009B    LD	0x1B,A
59:                   
60:                   // CCP2CON<5:4> хнШф╜О2ф╜Н: (dutyRaw & 0x03) << 4
61:                   // хЕИшп╗хЗ║ CCP2CONя╝Мц╕ЕщЩд bit5-4я╝МхЖНхЖЩхЕе
62:                   CCP2CON = (CCP2CON & 0xCF) | ((dutyRaw & 0x03) << 4);
  0528    0857    LD	A,0x57
  0529    3903    ANDIA	0x3
  052A    00D5    LD	0x55,A
  052B    0E55    SWAPA	0x55
  052C    39F0    ANDIA	0xF0
  052D    00D5    LD	0x55,A
  052E    081D    LD	A,0x1D
  052F    39CF    ANDIA	0xCF
  0530    0455    ORA	0x55
  0531    009D    LD	0x1D,A
  0532    0008    RET
63:               }
