4:                // хБЗшо╛ Fosc=16MHz, цМЗф╗дхСицЬЯ 0.25us (хжВцЮЬцШп1T) цИЦ 1us (хжВцЮЬцШп4T)
5:                // CMS79F726 щАЪх╕╕цШп 1T ?? цЯещШЕф╣ацГпя╝МщАЪх╕╕ш┐ЩщЗМчЪД ms х╗╢цЧ╢чФич▓ЧчХех╛кчОпхоЮчО░
6:                static void DelayMs(unsigned int ms) {
7:                    unsigned int i, j;
8:                    for (i = 0; i < ms; i++) {
9:                        for (j = 0; j < 1000; j++) {
10:                           asm("nop");
11:                           asm("clrwdt"); // хЦВчЛЧщШ▓цнвхдНф╜Н
12:                       }
13:                   }
14:               }
15:               
16:               void PTC_Init(void) {
17:                   // 1. щЕНч╜о RA4 ф╕║ш╛УхЗ║
18:                   TRISA &= ~(1 << 4); // RA4 Output
  07F2    1683    SETB	0x3,5
  07F3    1205    CLRB	0x5,4
19:                   
20:                   // 2. щЕНч╜о Timer2 ф╕║ 10kHz
21:                   // PR2 = 99
22:                   PR2 = PTC_PWM_PR2_VALUE;
  07F4    3063    LDIA	0x63
  07F5    0092    LD	0x12,A
23:                   
24:                   // T2CON щЕНч╜о
25:                   // bit 6-3: TOUTPS (хРОхИЖщвС), шо╛ф╕║ 1:1 -> 0000
26:                   // bit 2:   TMR2ON (ф╜┐шГ╜), шо╛ф╕║ 1
27:                   // bit 1-0: T2CKPS (щвДхИЖщвС), шо╛ф╕║ 1:4 -> 01
28:                   // 0000 0101 = 0x05
29:                   T2CON = 0x05; 
  07F6    3005    LDIA	0x5
  07F7    1283    CLRB	0x3,5
  07F8    0092    LD	0x12,A
30:                   
31:                   // 3. щЕНч╜о CCP2 ф╕║ PWM цибх╝П
32:                   // CCP2CON:
33:                   // bit 5-4: CCP2X, CCP2Y (хНачй║цпФф╜О2ф╜Н)
34:                   // bit 3-0: CCP2M (цибх╝П), PWMцибх╝П = 11xx (ш┐ЩщЗМчФи 1100)
35:                   CCP2CON = 0x0C; // PWM mode
  07F9    300C    LDIA	0xC
  07FA    009D    LD	0x1D,A
36:                   
37:                   // хИЭхзЛхНачй║цпФ 0
38:                   CCPR2L = 0;
  07FB    019B    CLR	0x1B
39:                   
40:                   // чбоф┐Э Timer2 ф╕нцЦнх╝АхРп (хжВцЮЬф╣ЛхЙНхЬи main ф╕нх╖▓ч╗Пх╝Аф║Жя╝Мш┐ЩщЗМхЖНцмбчбошод)
41:                   TMR2IE = 1;
  07FC    1683    SETB	0x3,5
  07FD    148C    SETB	0xC,1
  07FE    0008    RET
42:               }
